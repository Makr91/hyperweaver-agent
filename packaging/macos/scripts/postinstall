#!/bin/bash
# Hyperweaver Agent pkg postinstall: plant the STARTcloud PKI at the ONE
# elevated moment (Mark's shape-A ruling, sync 2026-07-17) — the OFFLINE
# root's certificate is the trust anchor (yearly intermediate rotation never
# re-prompts), and the intermediate lands beside it so chains build. The
# intermediate pair also rides inside the app bundle
# (Contents/Resources/ssl-seed); the agent copies it into its config dir on
# first TLS start, signs its certificates from it, and serves the full chain.
#
# Never fail the install over trust settings: recent macOS versions can
# require interactive approval for trust changes — the certificate is still
# imported and the user can approve it in Keychain Access.
SEED="/Applications/HyperweaverAgent.app/Contents/Resources/ssl-seed"
if [ -f "$SEED/root-ca.crt" ]; then
    security add-trusted-cert -d -r trustRoot \
        -k /Library/Keychains/System.keychain "$SEED/root-ca.crt" || true
fi
if [ -f "$SEED/ca.crt" ]; then
    security add-certificates -k /Library/Keychains/System.keychain "$SEED/ca.crt" || true
fi
exit 0
