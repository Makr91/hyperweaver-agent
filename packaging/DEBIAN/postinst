#!/bin/bash
set -e

# Create system user and group for headless service mode
if ! getent passwd hyperweaver-agent > /dev/null 2>&1; then
    adduser --system --group --home /var/lib/hyperweaver-agent \
            --no-create-home --shell /usr/sbin/nologin \
            --gecos "Hyperweaver Agent system user" hyperweaver-agent
fi

# Runtime directories
mkdir -p /var/lib/hyperweaver-agent
mkdir -p /var/log/hyperweaver-agent

# Set ownership and permissions
chown -R hyperweaver-agent:hyperweaver-agent /var/lib/hyperweaver-agent
chown -R hyperweaver-agent:hyperweaver-agent /var/log/hyperweaver-agent
chown -R hyperweaver-agent:hyperweaver-agent /etc/hyperweaver-agent
chmod 750 /etc/hyperweaver-agent

# Reload systemd daemon
systemctl daemon-reload || true

echo ""
echo "======================================================================"
echo "Hyperweaver Agent has been installed successfully!"
echo ""
echo "Desktop (tray) mode:"
echo "  Launch 'Hyperweaver Agent' from your application menu."
echo "  Note: stock GNOME needs the AppIndicator extension to show tray icons."
echo ""
echo "Headless service mode:"
echo "1. Review configuration: /etc/hyperweaver-agent/config.yaml"
echo "2. Start the service: systemctl enable --now hyperweaver-agent"
echo "3. Check status: systemctl status hyperweaver-agent"
echo "4. View logs: journalctl -u hyperweaver-agent -f"
echo ""
echo "Default access: http://127.0.0.1:9420/ui/"
echo "======================================================================"
echo ""

#DEBHELPER#
