#!/bin/bash
set -e

case "$1" in
    remove)
        # Keep user, data, and config for potential reinstall
        echo "Hyperweaver Agent removed but user and data preserved"
        ;;
    purge)
        # Remove everything including user and data
        echo "Purging Hyperweaver Agent completely..."

        # Remove system user
        if getent passwd hyperweaver-agent > /dev/null 2>&1; then
            deluser hyperweaver-agent || true
        fi

        # Remove data directories (user confirmation should happen via apt/dpkg)
        rm -rf /var/lib/hyperweaver-agent
        rm -rf /var/log/hyperweaver-agent
        rm -rf /etc/hyperweaver-agent

        echo "Hyperweaver Agent completely removed"
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Do nothing for these cases
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

# Reload systemd daemon
systemctl daemon-reload || true

#DEBHELPER#
