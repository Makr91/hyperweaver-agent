# Normalize line endings: text files are stored as LF in the repository.
* text=auto

# Go source is always LF (gofmt output)
*.go    text eol=lf
go.mod  text eol=lf
go.sum  text eol=lf

# Files executed on Linux/macOS must be LF in the working tree too.
# A CRLF shebang in the Debian maintainer scripts makes dpkg fail to exec
# them ("No such file or directory") — keep them explicitly LF.
*.sh    text eol=lf
packaging/DEBIAN/postinst  text eol=lf
packaging/DEBIAN/prerm     text eol=lf
packaging/DEBIAN/postrm    text eol=lf

# Windows-only scripts stay CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never convert
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.exe   binary
*.pkg   binary
*.dmg   binary
