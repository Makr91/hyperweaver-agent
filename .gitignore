# Build outputs
/bin/
/dist/
/hyperweaver-agent
/hyperweaver-agent.exe
*.syso

# The Hyperweaver UI artifact is baked into internal/webui/dist at release
# build time; only the committed placeholder index.html belongs in git.
internal/webui/dist/*
!internal/webui/dist/index.html

# Local dev copy of the UI (ui.path target; populated by copying
# hyperweaver-ui's dist here — see README)
/ui/

# Go workspace files
go.work
go.work.sum

# Logs
logs/
*.log

# Local dev config + credentials that live beside it
/config.yaml
/keys.json
/setup.token

# SSL certificates / keys
ssl/
*.key
*.crt
*.pem
*.p12
*.pfx

# packaging/ssl is NOT committed (Mark's ruling 2026-07-17 — the retired
# in-repo pair died with the PKI rotation): release CI populates it from the
# core_provisioner release pinned in driver.version (build-packages.yml's
# "Stage STARTcloud PKI" step; the generic ssl/ + *.crt/*.key patterns above
# already ignore the tree). Local installer builds run the same fetch by hand.

# Packaging outputs
*.deb
*.p5p
*.pkg
*.dmg
*.nupkg

# OS cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# IDE
.idea/

# Scratch notes
SCRATCH_NOTES.md
