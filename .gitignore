# Build outputs
/bin/
/dist/
/hyperweaver-agent
/hyperweaver-agent.exe
*.syso

# The Hyperweaver UI artifact is baked into internal/webui/dist at release
# build time; only the committed placeholder index.html belongs in git.
internal/webui/dist/*
!internal/webui/dist/index.html

# Local dev copy of the UI (ui.path target; populated by copying
# hyperweaver-ui's dist here — see README)
/ui/

# Go workspace files
go.work
go.work.sum

# Logs
logs/
*.log

# Local dev config + credentials that live beside it
/config.yaml
/keys.json
/setup.token

# SSL certificates / keys
ssl/
*.key
*.crt
*.pem
*.p12
*.pfx

# EXCEPTION: the installer-seeded STARTcloud CA pair ships in the repo
# deliberately (Mark's ruling, 2026-07-05) — release builds copy it into
# every installer (Inno ssl-seed, deb /etc ssl staging, macOS Resources/
# ssl-seed) so agents sign their server certificates against one trusted
# chain. The directory must be re-included before files inside it can be.
!packaging/ssl/
!packaging/ssl/ca-certificate.crt
!packaging/ssl/ca-certificate.key

# Packaging outputs
*.deb
*.p5p
*.pkg
*.dmg
*.nupkg

# OS cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# IDE
.idea/

# Scratch notes
SCRATCH_NOTES.md
